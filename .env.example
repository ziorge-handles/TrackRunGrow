# Database (Supabase)
DATABASE_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres"

# Auth (Auth.js / NextAuth v5)
AUTH_SECRET="run: openssl rand -base64 32"
# Public site URL (no trailing slash). In production set to https://your-domain.com
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
# Trust Host — set true on Vercel / behind a proxy if sign-in returns 500 / UntrustedHost
AUTH_TRUST_HOST="true"

# AI
ANTHROPIC_API_KEY="sk-ant-..."

# Payments (Stripe) — required for pricing checkout; use live keys on production
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Price IDs from Stripe Dashboard (recommended). If unset, the app looks up by product ID in code (must match your Stripe account).
STRIPE_BASIC_PRICE_ID="price_..."
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_ENTERPRISE_PRICE_ID="price_..."

# Email (SendGrid)
SENDGRID_API_KEY="SG...."
SENDGRID_FROM_EMAIL="TrackRunGrow <noreply@trackrungrow.com>"
CONTACT_FORM_TO_EMAIL="ryanmelvin@trackrungrow.com"

# Storage (Supabase)
NEXT_PUBLIC_SUPABASE_URL="https://[project].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Error Monitoring (Sentry)
NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
